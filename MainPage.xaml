<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MathToolsApp.MainPage"
             Title="Math Tools">
    
    <VerticalStackLayout Spacing="20" Padding="20" VerticalOptions="Center">
        <Label Text="🧮 MATH TOOLS" 
               FontSize="28" 
               FontAttributes="Bold"
               HorizontalOptions="Center"/>
        
        <Label Text="App is Working Perfectly!" 
               FontSize="16"
               HorizontalOptions="Center"
               TextColor="Green"/>
        
        <Button x:Name="AlgebraBtn" 
                Text="📐 Algebra Solver" 
                BackgroundColor="#2196F3"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="50"/>
        
        <Button x:Name="CalculusBtn" 
                Text="∫ Calculus" 
                BackgroundColor="#4CAF50"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="50"/>
        
        <Button x:Name="StatsBtn" 
                Text="📊 Statistics" 
                BackgroundColor="#FF9800"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="50"/>
        
        <Button x:Name="ConverterBtn" 
                Text="🔄 Unit Converter" 
                BackgroundColor="#9C27B0"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="50"/>
        
        <Button x:Name="MatrixBtn" 
                Text="🔢 Matrix Calculator" 
                BackgroundColor="#F44336"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="50"/>
    </VerticalStackLayout>
</ContentPage>